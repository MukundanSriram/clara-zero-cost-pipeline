{
  "name": "Clara Demo Pipeline - Batch v1 Generation",
  "nodes": [
    {
      "id": "1",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [260, 300]
    },
    {
      "id": "2",
      "name": "Run Demo Pipeline Script",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 2,
      "position": [600, 300],
      "parameters": {
        "command": "python3 scripts/process_demo_calls.py --demo-dir \"{{ $env.DATASET_DEMO_DIR || 'dataset/demo' }}\" --outputs-dir \"{{ $env.OUTPUTS_DIR || 'outputs/accounts' }}\""
      }
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Run Demo Pipeline Script",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionTimeout": -1
  },
  "tags": [
    { "name": "clara" },
    { "name": "demo" }
  ]
}